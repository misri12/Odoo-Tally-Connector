<odoo>

    <record id="generate_xml_form" model="ir.ui.view">
        <field name="name">tally.generate.xml.form</field>
        <field name="model">tally.generate.xml</field>
        <field name="arch" type="xml">

            <form string="Generate Tally XML">

                <sheet>

                    <group>
                        <field name="configuration_id"/>
                        <field name="company_id" readonly="1"/>
                    </group>

                    <group string="Date Range">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>

                    <group string="Document Types">
                        <field name="export_customer_invoices"/>
                        <field name="export_vendor_bills"/>
                        <field name="export_credit_notes"/>
                        <field name="export_debit_notes"/>
                        <field name="export_customer_payments"/>
                        <field name="export_vendor_payments"/>
                    </group>

                    <notebook>

                        <page string="Invoices / Bills">
                            <field name="invoice_ids" widget="many2many_tags"/>
                        </page>

                        <page string="Payments">
                            <field name="payment_ids" widget="many2many_tags"/>
                        </page>

                    </notebook>

                </sheet>

                <footer>
                    <button
                        name="action_generate_xml"
                        string="Generate XML"
                        type="object"
                        class="btn-primary"/>

                    <button
                        string="Cancel"
                        special="cancel"
                        class="btn-secondary"/>
                </footer>

            </form>

        </field>
    </record>

    <record id="generate_xml_action" model="ir.actions.act_window">
        <field name="name">Generate Tally XML</field>
        <field name="res_model">tally.generate.xml</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>



