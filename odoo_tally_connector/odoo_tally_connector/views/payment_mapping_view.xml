<odoo>
    <record id="payment_mapping_tree" model="ir.ui.view">
        <field name="name">tally.payment.mapping.tree</field>
        <field name="model">tally.payment.mapping</field>
        <field name="arch" type="xml">
            <tree>
                <field name="company_id"/>
                <field name="journal_id"/>
                <field name="tally_ledger_name"/>
            </tree>
        </field>
    </record>

    <record id="payment_mapping_form" model="ir.ui.view">
        <field name="name">tally.payment.mapping.form</field>
        <field name="model">tally.payment.mapping</field>
        <field name="arch" type="xml">
            <form string="Tally Payment Mapping">
                <sheet>
                    <group>
                        <field name="company_id"/>
                        <field name="configuration_id"/>
                    </group>
                    <group>
                        <field name="journal_id"/>
                        <field name="tally_ledger_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="payment_mapping_action" model="ir.actions.act_window">
        <field name="name">Tally Payment Mapping</field>
        <field name="res_model">tally.payment.mapping</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
    </record>
</odoo>

